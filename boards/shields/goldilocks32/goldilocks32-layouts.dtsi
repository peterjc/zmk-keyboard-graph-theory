#include <physical_layouts.dtsi>


    /* Physical layout close to this:
     *
     * ┌───┬───┬───┬───┐                   ┌───┬───┬───┬───┐
     * │ Q │ W │ E │ R ├───┐           ┌───┤ U │ I │ O │ P │
     * ├───┼───┼───┼───┤ T │           │ Y ├───┼───┼───┼───┤
     * │ A │ S │ D │ F ├───┤           ├───┤ J │ K │ L │ ; │
     * ├───┼───┼───┼───┤ G │           │ H ├───┼───┼───┼───┤
     * │ Z │ X │ C │ V ├───┘           └───┤ M │ , │ . │ / │
     * └───┴───┴───┴───┘                   └───┴───┴───┴───┘
     *                 ┌───┬───┐  ┌───┬───┐
     *      (5-way)    │ B │BkS│  │SPC│ N │
     *                 └───┴───┘  └───┴───┘
     *
     * Logical rows as used in the DTSI file:
     *
     * Q 	W 	E 	R 	T 	   	Y 	U 	I 	O 	P
     * A 	S 	D 	F 	G 	   	H 	J 	K 	L 	;
     * Z 	X 	C 	V 	B 	   	N 	M 	, 	. 	/
     *   	  	  	⬆️	⬅️	⏺️	➡️	⬇️
     *   	  	  	  	⌫ 	   	␠
     *
     * The RC(#, #) columns and row value below are the scaning matrix (GPIOs), not physical/logical!
     * Scannig cols 0-7 on left, then 8-15 on the right with row 8 just for the 5-way nav.
     * The layout variant drops the thumb-keys listed at the end.
     */

/ {
    matrix_transform32: matrix_transform32 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <9>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3)  RC(4,4)          RC(6,11) RC(5,12) RC(6,13) RC(5,14) RC(2,15)
            RC(1,0) RC(2,1) RC(3,2) RC(4,3)  RC(7,4)          RC(4,11) RC(4,12) RC(1,13) RC(1,14) RC(6,15)
            RC(7,5) RC(1,5) RC(2,6) RC(7,6)  RC(3,7)          RC(2,8)  RC(5,9)  RC(3,9)  RC(3,10) RC(6,10)
                                    RC(8,12) RC(8,6) RC(8,13) RC(8,7)  RC(8,3)
                                             RC(7,7)          RC(5,8)
        >;
    };

    matrix_transform30: matrix_transform30 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <9>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3)  RC(4,4)          RC(6,11) RC(5,12) RC(6,13) RC(5,14) RC(2,15)
            RC(1,0) RC(2,1) RC(3,2) RC(4,3)  RC(7,4)          RC(4,11) RC(4,12) RC(1,13) RC(1,14) RC(6,15)
            RC(7,5) RC(1,5) RC(2,6) RC(7,6)  RC(3,7)          RC(2,8)  RC(5,9)  RC(3,9)  RC(3,10) RC(6,10)
                                    RC(8,12) RC(8,6) RC(8,13) RC(8,7)  RC(8,3)
        >;
    };

    physical_layout32: physical_layout32 {
        compatible = "zmk,physical-layout";
        display-name = "32-keys";

        input = <&matrix>;
        transform = <&matrix_transform32>;
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 140   36   33    1000    86    83>
            , <&key_physical_attrs 100 100  139    5    1000   189    55>
            , <&key_physical_attrs 100 100  274    0    1800   324    50>
            , <&key_physical_attrs 100 100  367   89    2200   417   139>
            , <&key_physical_attrs 100 100  443  179    2200   493   229>
            , <&key_physical_attrs 100 100  675  179 (-2200)   725   229>
            , <&key_physical_attrs 100 100  751   89 (-2200)   801   139>
            , <&key_physical_attrs 100 100  844    0 (-1800)   894    50>
            , <&key_physical_attrs 100 100  979    5 (-1000)  1029    55>
            , <&key_physical_attrs 100 140 1082   33 (-1000)  1132    83>
            , <&key_physical_attrs 100 100    0  173       0     0   173>
            , <&key_physical_attrs 100 100  123  107    1000   173   157>
            , <&key_physical_attrs 100 100  246   98    1800   296   148>
            , <&key_physical_attrs 100 100  333  185    2200   383   235>
            , <&key_physical_attrs 100 100  409  275    2200   459   325>
            , <&key_physical_attrs 100 100  709  275 (-2200)   759   325>
            , <&key_physical_attrs 100 100  785  185 (-2200)   835   235>
            , <&key_physical_attrs 100 100  872   98 (-1800)   922   148>
            , <&key_physical_attrs 100 100  995  107 (-1000)  1045   157>
            , <&key_physical_attrs 100 100 1118  173       0  1118   173>
            , <&key_physical_attrs 100 100    0  276       0     0   276>
            , <&key_physical_attrs 100 100  107  209    1000   157   259>
            , <&key_physical_attrs 100 100  217  196    1800   267   246>
            , <&key_physical_attrs 100 100  299  280    2200   349   330>
            , <&key_physical_attrs 100 100  348  420    3700   398   470>
            , <&key_physical_attrs 100 100  770  420 (-3700)   820   470>
            , <&key_physical_attrs 100 100  819  280 (-2200)   869   330>
            , <&key_physical_attrs 100 100  901  196 (-1800)   951   246>
            , <&key_physical_attrs 100 100 1011  209 (-1000)  1061   259>
            , <&key_physical_attrs 100 100 1118  276       0  1118   276>
            , <&key_physical_attrs  90  90  125  312       0   125   312>
            , <&key_physical_attrs  90  90   35  402       0    35   402>
            , <&key_physical_attrs  90  90  125  402       0   125   402>
            , <&key_physical_attrs  90  90  215  402       0   215   402>
            , <&key_physical_attrs  90  90  125  492       0   125   492>
            , <&key_physical_attrs 100 100  428  488    3700   478   538>
            , <&key_physical_attrs 100 100  690  488 (-3700)   740   538>
            ;
    };

    physical_layout30: physical_layout30 {
        compatible = "zmk,physical-layout";
        display-name = "30-key";

        input = <&matrix>;
        transform = <&matrix_transform30>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 140   36   33    1000    86    83>
            , <&key_physical_attrs 100 100  139    5    1000   189    55>
            , <&key_physical_attrs 100 100  274    0    1800   324    50>
            , <&key_physical_attrs 100 100  367   89    2200   417   139>
            , <&key_physical_attrs 100 100  443  179    2200   493   229>
            , <&key_physical_attrs 100 100  675  179 (-2200)   725   229>
            , <&key_physical_attrs 100 100  751   89 (-2200)   801   139>
            , <&key_physical_attrs 100 100  844    0 (-1800)   894    50>
            , <&key_physical_attrs 100 100  979    5 (-1000)  1029    55>
            , <&key_physical_attrs 100 140 1082   33 (-1000)  1132    83>
            , <&key_physical_attrs 100 100    0  173       0     0   173>
            , <&key_physical_attrs 100 100  123  107    1000   173   157>
            , <&key_physical_attrs 100 100  246   98    1800   296   148>
            , <&key_physical_attrs 100 100  333  185    2200   383   235>
            , <&key_physical_attrs 100 100  409  275    2200   459   325>
            , <&key_physical_attrs 100 100  709  275 (-2200)   759   325>
            , <&key_physical_attrs 100 100  785  185 (-2200)   835   235>
            , <&key_physical_attrs 100 100  872   98 (-1800)   922   148>
            , <&key_physical_attrs 100 100  995  107 (-1000)  1045   157>
            , <&key_physical_attrs 100 100 1118  173       0  1118   173>
            , <&key_physical_attrs 100 100    0  276       0     0   276>
            , <&key_physical_attrs 100 100  107  209    1000   157   259>
            , <&key_physical_attrs 100 100  217  196    1800   267   246>
            , <&key_physical_attrs 100 100  299  280    2200   349   330>
            , <&key_physical_attrs 170 100  370  406    3700   420   456>
            , <&key_physical_attrs 170 100  698  446 (-3700)   748   506>
            , <&key_physical_attrs 100 100  819  280 (-2200)   869   330>
            , <&key_physical_attrs 100 100  901  196 (-1800)   951   246>
            , <&key_physical_attrs 100 100 1011  209 (-1000)  1061   259>
            , <&key_physical_attrs 100 100 1118  276       0  1118   276>
            , <&key_physical_attrs  90  90  125  312       0   125   312>
            , <&key_physical_attrs  90  90   35  402       0    35   402>
            , <&key_physical_attrs  90  90  125  402       0   125   402>
            , <&key_physical_attrs  90  90  215  402       0   215   402>
            , <&key_physical_attrs  90  90  125  492       0   125   492>
            ;
    };
};

/ {
    position_map {
        compatible = "zmk,physical-layout-position-map";

        physical_layout32 {
            physical-layout = <&physical_layout32>;
            positions = <24 25 35 36>;
        };

        physical_layout30 {
            physical-layout = <&physical_layout30>;
            positions = <24 25 35 36>;
        };
    };
};

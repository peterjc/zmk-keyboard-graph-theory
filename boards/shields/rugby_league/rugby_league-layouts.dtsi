#include <physical_layouts.dtsi>

    /* Physical layout close to this:
     *
     * в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ          в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ
     * в”Ӯ Q в”Ӯ W в”Ӯ E в”Ӯ R в”ңв”Җв”Җв”Җв”җ  в”Ңв”Җв”Җв”Җв”Ө U в”Ӯ I в”Ӯ O в”Ӯ P в”Ӯ
     * в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө T в”Ӯ  в”Ӯ Y в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө
     * в”Ӯ A в”Ӯ S в”Ӯ D в”Ӯ F в”ңв”Җв”Җв”Җв”Ө  в”ңв”Җв”Җв”Җв”Ө J в”Ӯ K в”Ӯ L в”Ӯ ; в”Ӯ
     * в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө G в”Ӯ  в”Ӯ H в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө
     * в”Ӯ Z в”Ӯ X в”Ӯ C в”Ӯ V в”ңв”Җв”Җв”Җв”ҳ  в””в”Җв”Җв”Җв”Ө M в”Ӯ , в”Ӯ . в”Ӯ / в”Ӯ
     * в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ          в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ
     *                 в”Ңв”Җв”Җв”Җв”җ  в”Ңв”Җв”Җв”Җв”җ
     *                 в”Ӯ B в”Ӯ  в”Ӯ N в”Ӯ
     *                 в””в”Җв”Җв”Җв”ҳ  в””в”Җв”Җв”Җв”ҳ
     *
     * Logical rows as used in the DTSI file:
     *
     * Q        W       E       R       T          Y       U       I       O       P
     * A        S       D       F       G          H       J       K       L       ;
     * Z        X       C       V       B          N       M       ,       .       /
     *
     * The RC(#, #) columns and row value below are the direct wired scanning matrix
     * where row 0 is left, row 1 is right, and columns 0 to 14 are the 15 GPIOs.
     */

/ {

    matrix_transform30: matrix_transform30 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <15>;
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)     RC(1,4)  RC(1,3)  RC(1,2)  RC(1,1)  RC(1,0)
            RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)     RC(1,9)  RC(1,8)  RC(1,7)  RC(1,6)  RC(1,5)
            RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)    RC(1,14) RC(1,13) RC(1,12) RC(1,11) RC(1,10)
        >;
    };

    physical_layout30: physical_layout30 {
        compatible = "zmk,physical-layout";
        display-name = "LAYOUT";

        kscan = <&kscan0>;
        transform = <&matrix_transform30>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 150  114    0    3200   164    69>
            , <&key_physical_attrs 100 100  223   36    3200   269    86>
            , <&key_physical_attrs 100 100  346   84    4000   396   134>
            , <&key_physical_attrs 100 100  403  199    4400   453   249>
            , <&key_physical_attrs 100 100  443  308    4400   493   358>
            , <&key_physical_attrs 100 100  732  308 (-4400)   782   358>
            , <&key_physical_attrs 100 100  772  200 (-4400)   822   250>
            , <&key_physical_attrs 100 100  829   85 (-4000)   879   135>
            , <&key_physical_attrs 100 100  955   36 (-3200)  1006    86>
            , <&key_physical_attrs 100 150 1061    0 (-3200)  1111    70>
            , <&key_physical_attrs 100 100   34  126    2200    84   176>
            , <&key_physical_attrs 100 100  170  118    3200   220   168>
            , <&key_physical_attrs 100 100  287  159    4000   337   209>
            , <&key_physical_attrs 100 100  339  269    4400   389   319>
            , <&key_physical_attrs 100 100  379  378    4400   429   428>
            , <&key_physical_attrs 100 100  795  378 (-4400)   845   428>
            , <&key_physical_attrs 100 100  836  270 (-4400)   886   320>
            , <&key_physical_attrs 100 100  888  159 (-4000)   938   209>
            , <&key_physical_attrs 100 100 1004  119 (-3200)  1054   169>
            , <&key_physical_attrs 100 100 1140  127 (-2200)  1190   177>
            , <&key_physical_attrs 100 100    0  216    2200    50   266>
            , <&key_physical_attrs 100 100  120  200    3200   172   250>
            , <&key_physical_attrs 100 100  228  233    4000   278   283>
            , <&key_physical_attrs 100 100  275  339    4400   325   389>
            , <&key_physical_attrs 175 100  272  520    5900   360   570>
            , <&key_physical_attrs 175 100  828  520 (-5900)   915   570>
            , <&key_physical_attrs 100 100  899  340 (-4400)   949   390>
            , <&key_physical_attrs 100 100  947  234 (-4000)   997   284>
            , <&key_physical_attrs 100 100 1055  201 (-3200)  1103   251>
            , <&key_physical_attrs 100 100 1175  217 (-2200)  1225   267>
            ;
    };
};

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout30;
    };
};

